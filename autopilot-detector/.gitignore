# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# This repo uses bun workspaces (bun.lock is the source of truth).
# Ignore npm/yarn/pnpm lockfiles so an accidental `npm install` can't reintroduce them.
package-lock.json
yarn.lock
pnpm-lock.yaml

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Redis snapshots (runtime data — may contain real session signals)
*.rdb

# Python (apps/ml)
__pycache__/
*.pyc
.venv/
venv/
