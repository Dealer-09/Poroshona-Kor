generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum AppIntent {
  STUDY
  TUTORIAL
  ENTERTAINMENT
  PRODUCTIVITY
  PASSIVE
}

enum InterventionType {
  NUDGE
  PAUSE
  REFLECTION
  SLEEP_MODE
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  password     String
  createdAt    DateTime    @default(now())
  groqApiKey   String?     // User's personal Groq key for classification & chat
  geminiApiKey String?     // User's personal Gemini key for vector embeddings
  sessions     Session[]
  moodEntries  MoodEntry[]
}

model Session {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @db.Uuid
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  appOpened      String
  declaredIntent AppIntent
  pageTitle      String?
  pageCategory   String?
  moodRating     Int?               // 1–5 scale, null if not rated, set post-session
  scores         AutopilotScore[]
  interventions  Intervention[]
  embeddings     SessionEmbedding[]
  moodEntry      MoodEntry?
}

model AutopilotScore {
  id                    String   @id @default(uuid()) @db.Uuid
  sessionId             String   @db.Uuid
  session               Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  score                 Float
  focusFragmentation    Float
  passiveRatio          Float
  cognitiveDrift        Float
  doomscrollProbability Float
  timestamp             DateTime @default(now())
}

model Intervention {
  id          String           @id @default(uuid()) @db.Uuid
  sessionId   String           @db.Uuid
  session     Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        InterventionType
  message     String
  triggeredAt DateTime         @default(now())
}

model SessionEmbedding {
  id        String                    @id @default(uuid()) @db.Uuid
  sessionId String                    @db.Uuid
  session   Session                   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(512)")
}

// Stage 2: Post-session mood tracking for correlation chart
model MoodEntry {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  sessionId  String   @unique @db.Uuid
  moodRating Int      // 1–5: 1=Drained, 2=Meh, 3=Neutral, 4=Good, 5=Energized
  avgScore   Float    // average autopilot score for that session
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id])
}